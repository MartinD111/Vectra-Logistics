# General config
NODE_ENV=development
PORT=8080

# Database
POSTGRES_USER=vectra_user
POSTGRES_PASSWORD=vectra_password
POSTGRES_DB=vectra_db
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgres://vectra_user:vectra_password@postgres:5432/vectra_db

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379

# Auth
JWT_SECRET=vectra-dev-secret-key-change-in-production

# Microservices
MATCHING_ENGINE_URL=http://matching-engine:8000
BACKEND_API_URL=http://api:8080

# Frontend — shared by all three apps
NEXT_PUBLIC_API_URL=http://localhost:8080

# Cross-app URLs (app-switcher + cross-app links). In production set these to
# the per-app subdomains, e.g. https://app.vectra.app
NEXT_PUBLIC_MARKETPLACE_URL=http://localhost:3000
NEXT_PUBLIC_WORKSPACES_URL=http://localhost:3001
NEXT_PUBLIC_CMR_URL=http://localhost:3002

# SSO cookie domain. Leave UNSET in dev (host-only cookie on localhost, shared
# across ports). In production set to the parent domain to share the session
# across subdomains, e.g. .vectra.app
# NEXT_PUBLIC_COOKIE_DOMAIN=.vectra.app

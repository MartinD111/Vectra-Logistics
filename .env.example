# General config
NODE_ENV=development
PORT=8080

# Database
POSTGRES_USER=vectra_user
POSTGRES_PASSWORD=vectra_password
POSTGRES_DB=vectra_db
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgres://vectra_user:vectra_password@postgres:5432/vectra_db

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379

# Auth
# Generate both JWT_SECRET and ENCRYPTION_KEY with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=
ENCRYPTION_KEY=

# Deployment mode — must be exactly `cloud` or `on-prem`. The server refuses to
# boot otherwise (D-02). `cloud` preserves today's behavior (open registration).
# `on-prem` closes /api/auth/signup (403) and is written automatically by the
# Phase 17 installer — do not set `on-prem` manually unless you know the
# single-company/admin path is already provisioned another way.
DEPLOYMENT_MODE=

# Microservices
MATCHING_ENGINE_URL=http://matching-engine:8000
BACKEND_API_URL=http://api:8080

# API public URL — required by docker-compose.prod.yml's api service. In
# production set to the API's externally-reachable URL, e.g. https://api.vectra.app
API_PUBLIC_URL=http://localhost:8080

# Workspaces app URL — required by docker-compose.prod.yml's api service
# (used for cross-app links/redirects, and as the Outlook OAuth callback
# return target when Outlook integration is enabled below).
WORKSPACES_APP_URL=http://localhost:3001

# Outlook / Microsoft 365 integration (optional). Leave unset to run the Outlook
# connector in DEMO mode (connecting is simulated). Set all three to enable the
# real OAuth sign-in. See docs/DEPLOYMENT.md for the Entra app-registration steps.
# MS_CLIENT_ID=
# MS_CLIENT_SECRET=
# MS_REDIRECT_URI=http://localhost:8080/api/v1/outlook/callback
# MS_TENANT=common

# Frontend — shared by all three apps
NEXT_PUBLIC_API_URL=http://localhost:8080

# Cross-app URLs (app-switcher + cross-app links). In production set these to
# the per-app subdomains, e.g. https://app.vectra.app
NEXT_PUBLIC_MARKETPLACE_URL=http://localhost:3000
NEXT_PUBLIC_WORKSPACES_URL=http://localhost:3001
NEXT_PUBLIC_CMR_URL=http://localhost:3002

# CORS / Socket.IO allowed origins (HRD-01). Comma-separated list of origins
# allowed to call the API (Express CORS + Socket.IO handshake). Leave unset
# to fall back to NEXT_PUBLIC_MARKETPLACE_URL/NEXT_PUBLIC_WORKSPACES_URL/
# NEXT_PUBLIC_CMR_URL, e.g. https://app.vectra.app,https://cmr.vectra.app
CORS_ALLOWED_ORIGINS=

# SSO cookie domain. Leave UNSET in dev (host-only cookie on localhost, shared
# across ports). In production set to the parent domain to share the session
# across subdomains, e.g. .vectra.app
# NEXT_PUBLIC_COOKIE_DOMAIN=.vectra.app
